// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// models: ver docs/03-DATABASE.md — adicionados na fase de schema

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  CARD_PAYMENT
}

// CREDIT = cartão de crédito tradicional (limite, fatura, ciclo — ver
// docs/22-CREDIT_CARDS.md). MEAL = cartão pré-pago tipo vale-alimentação/
// benefício (ex.: EVA Benefícios): SEM fatura/ciclo/limite de crédito, saldo
// derivado de recargas (Transaction INCOME no cartão) menos gastos
// (Transaction EXPENSE no cartão) — ver src/modules/cards/service.ts
// `mealBalance`.
enum CardType {
  CREDIT
  MEAL
}

// Status operacional do cartão. `Card.isActive` (abaixo) é derivado/
// sincronizado a partir daqui (ACTIVE → true, BLOCKED/CANCELLED → false)
// pelo module (src/modules/cards/repository.ts `update`) — nunca gravado
// direto pela UI. Existe pra reusar o filtro `isActive` já usado por
// modules/telegram/resolve.ts e o seletor de origem, sem alterá-los.
enum CardStatus {
  ACTIVE
  BLOCKED
  CANCELLED
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum AccountType {
  CHECKING
  SAVINGS
  CASH
  BUSINESS
  OTHER
}

enum AssetType {
  PROPERTY
  VEHICLE
  INVESTMENT
  FGTS
  EMERGENCY_FUND
  OTHER
}

enum AlertType {
  WEEKLY_SUMMARY
  ANOMALY
  GREEN
  RECURRING_SUGGESTION
}

// Origem do valor atual de uma SavingsGoal (docs/03-DATABASE.md, model
// SavingsGoal). MANUAL = `currentAmount` editado à mão pelo usuário; ACCOUNT =
// derivado do saldo de `sourceAccountId`; ASSET = derivado de
// `sourceAssetId.currentValue`. Só um dos dois FKs (`sourceAccountId`/
// `sourceAssetId`) é preenchido, e só quando `sourceType` correspondente.
enum GoalSourceType {
  MANUAL
  ACCOUNT
  ASSET
}

enum AlertSeverity {
  INFO
  WARN
  GOOD
}

enum RecurringFrequency {
  MONTHLY
  WEEKLY
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

// Juros do Loan é OPCIONAL (docs/03-DATABASE.md, model Loan) — só faz sentido
// junto de `interestRate`, nunca sozinho. ANNUAL = taxa efetiva ao ano
// (comum em contrato de empréstimo pessoal/bancário, ex. CDC/DDC); MONTHLY =
// taxa já ao mês. Conversão ANNUAL→mensal em `modules/loans/interest.ts`.
enum InterestPeriod {
  ANNUAL
  MONTHLY
}

// Loan estende para financiamento (docs/50-AUDITORIA-BACKLOG.md decisão:
// `Loan.kind`, não módulo novo — mesma entidade cobre empréstimo "simples" e
// financiamento de bem, cada um usando o subconjunto de campos que faz
// sentido). `LOAN` = comportamento atual (default, sem regressão para os
// empréstimos já existentes). `FINANCING` = habilita os campos específicos
// de financiamento no model `Loan` abaixo (entrada, valor do bem, sistema de
// amortização, CET, custos embutidos).
enum LoanKind {
  LOAN
  FINANCING
}

// Sistema de amortização do financiamento (`Loan.amortizationSystem`, só
// relevante quando `kind=FINANCING` — `null` em LOAN). PRICE = parcelas
// fixas (Tabela Price/francesa); SAC = amortização constante, parcela
// decrescente; CUSTOM = cronograma explícito (tabela extraída de um
// documento do banco, ver Stage 3/Gemini — não recalculado, usado como veio).
enum AmortizationSystem {
  PRICE
  SAC
  CUSTOM
}

// Benchmark de rendimento de Asset INVESTMENT (docs/28-INVESTMENTS.md).
// NONE = sem yield (imóvel/veículo/etc.); CDI = % do CDI (ex.: Cofrinho 115%).
enum YieldBenchmark {
  NONE
  CDI
}

// Índice de mercado cotado (cache diário — Gemini ou entrada manual).
enum MarketIndex {
  CDI
}

enum MarketIndexQuoteSource {
  GEMINI
  MANUAL
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts                 Account[]
  cards                    Card[]
  categories               Category[]
  tags                     Tag[]
  transactions             Transaction[]
  budgets                  Budget[]
  assets                   Asset[]
  installmentPurchases     InstallmentPurchase[]
  loans                    Loan[]
  recurringTransactions    RecurringTransaction[]
  alerts                   Alert[]
  savingsGoals             SavingsGoal[]
  settings                 UserSettings?
  telegramPendingEntry     TelegramPendingEntry?
  telegramProcessedUpdates TelegramProcessedUpdate[]
}

// ---------------------------------------------------------------------------
// Account
// ---------------------------------------------------------------------------

model Account {
  id             String      @id @default(cuid())
  userId         String
  name           String
  type           AccountType
  initialBalance Decimal     @db.Decimal(12, 2)
  color          String?
  icon           String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  loans                 Loan[]
  savingsGoals          SavingsGoal[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Card
// ---------------------------------------------------------------------------

model Card {
  id         String    @id @default(cuid())
  userId     String
  name       String
  brand      String
  // Imutável após a criação (docs/22-CREDIT_CARDS.md) — trocar o tipo de um
  // cartão já com Transactions mudaria a semântica dos dados existentes
  // (fatura calculada vs. saldo pré-pago). `src/modules/cards/schemas.ts` não
  // expõe `type` no update.
  type       CardType  @default(CREDIT)
  // `limit`/`closingDay`/`dueDay` só têm significado para CREDIT (docs/22).
  // Para MEAL, mantidos como placeholders ignorados pelo domínio (menos
  // disruptivo que tornar as colunas nullable — ver
  // src/modules/cards/schemas.ts `createCardSchema`); todo cálculo de
  // fatura/limite é guardado atrás de `card.type === CardType.CREDIT` em
  // `service.ts`.
  limit      Decimal   @db.Decimal(12, 2)
  closingDay Int
  dueDay     Int
  color      String?
  icon       String?
  // Só exibição (docs/22-CREDIT_CARDS.md não cobre "face de cartão realista" —
  // ver spec do frontend). `lastFour` NUNCA guarda o número completo, só os 4
  // últimos dígitos digitados pelo usuário (validado em
  // `src/modules/cards/schemas.ts`); `holderName` é o nome impresso, também
  // opcional.
  lastFour   String?
  holderName String?
  // Validade impressa, formato "MM/AA" (ex.: "12/28") — só exibição, mesma
  // regra de `lastFour`/`holderName` (opcional, sem cálculo de vencimento
  // real; validado em `src/modules/cards/schemas.ts`).
  expiry     String?
  // Status operacional (docs acima, `enum CardStatus`). `isActive` é
  // derivado/sincronizado a partir daqui pelo module (ACTIVE → true,
  // BLOCKED/CANCELLED → false) — os filtros de telegram/seletor de origem
  // continuam lendo `isActive`, sem precisar conhecer `status`.
  status     CardStatus @default(ACTIVE)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]
  installmentPurchases InstallmentPurchase[]
  cycles               CardCycle[]
  invoices             CardInvoice[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// CardCycle
// ---------------------------------------------------------------------------

// Histórico de mudança de ciclo (fechamento/vencimento) de um cartão — ver
// docs/22-CREDIT_CARDS.md. Um cartão SEM linhas aqui continua usando
// `Card.closingDay`/`Card.dueDay` direto (comportamento legado, zero
// regressão). Com linhas, o ciclo vigente numa data D é o `CardCycle` com
// maior `effectiveFrom <= D` (ver `src/modules/cards/cycle.ts`).
// Sem `userId` próprio — mesma exceção consciente de `TransactionTag`/
// `AssetSnapshot` (docs/03-DATABASE.md): isolamento vem da entidade-pai
// (`Card.userId`), nunca consultado sem passar por ela.
model CardCycle {
  id            String   @id @default(cuid())
  cardId        String
  closingDay    Int
  dueDay        Int
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, effectiveFrom])
}

// ---------------------------------------------------------------------------
// CardInvoice
// ---------------------------------------------------------------------------

// Fatura FECHADA real de um cartão, armazenada (não calculada) — ver
// docs/22-CREDIT_CARDS.md. Cobre o caso de dados IMPORTADOS de extrato real,
// onde agrupar Transaction por ciclo (`src/modules/cards/cycle.ts`) não bate:
// parcelas de parcelamento são faturadas em datas que não seguem a data da
// compra. A fatura ABERTA (ciclo atual) continua CALCULADA via
// `cardService.currentInvoice` — este model é só para HISTÓRICO de faturas já
// fechadas. Sem `userId` próprio — mesma exceção consciente de `CardCycle`/
// `TransactionTag`/`AssetSnapshot` (docs/03-DATABASE.md): isolamento vem da
// entidade-pai (`Card.userId`), nunca consultado sem passar por ela.
model CardInvoice {
  id          String    @id @default(cuid())
  cardId      String
  year        Int
  month       Int
  dueDate     DateTime
  total       Decimal   @db.Decimal(12, 2)
  isPaid      Boolean   @default(true)
  periodStart DateTime?
  periodEnd   DateTime?
  createdAt   DateTime  @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, year, month])
  @@index([cardId, dueDate])
}

// ---------------------------------------------------------------------------
// Category
// ---------------------------------------------------------------------------

model Category {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      CategoryType
  icon      String?
  color     String?
  parentId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent                Category?              @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children              Category[]             @relation("CategoryHierarchy")
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  loans                 Loan[]

  @@index([userId, parentId])
}

// ---------------------------------------------------------------------------
// Tag
// ---------------------------------------------------------------------------

model Tag {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionTags TransactionTag[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// TransactionTag (N:N junction — sem userId próprio, ver 03-DATABASE.md)
// ---------------------------------------------------------------------------

model TransactionTag {
  transactionId String
  tagId         String

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@index([tagId])
}

// ---------------------------------------------------------------------------
// Transaction (CORE)
// ---------------------------------------------------------------------------

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  description String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)

  categoryId String?
  accountId  String?
  cardId     String?

  date  DateTime
  notes String?

  isPaid Boolean @default(true)

  // Momento em que `isPaid` virou `true` (docs/03-DATABASE.md) — setado só na
  // transição pendente→paga (`modules/transactions/service.ts` `updateTransaction`),
  // nunca na criação (transação que já nasce paga não tem uma transição pra
  // capturar). Null em transação ainda pendente OU paga desde antes deste
  // campo existir (dado legado) — a timeline de detalhe cai num fallback
  // nesse segundo caso (ver `TransactionDetailModal`).
  paidAt DateTime?

  transferId String?

  // Id único do lançamento no extrato OFX de origem (`<FITID>`) — usado só
  // para dedup na importação (docs/03-DATABASE.md, "Importação de Extrato
  // OFX"): reimportar o mesmo arquivo não duplica lançamentos já existentes
  // na mesma conta. Null em toda Transaction que não veio de importação OFX
  // (a imensa maioria) e também no raro caso de um `<STMTTRN>` sem `<FITID>`
  // no arquivo — nesse caso o módulo de importação (`modules/imports/`) cai
  // num fallback de dedup por (accountId+date+amount+description) em vez
  // deste campo. Unicidade: índice único PARCIAL
  // `Transaction_accountId_fitId_key` em (accountId, fitId)
  // WHERE fitId IS NOT NULL AND deletedAt IS NULL — em SQL cru (migration
  // `transaction_fitid_unique`) porque Prisma não modela unique parcial.
  // Parcial de propósito: soft-deleted fica fora (reimportar um lançamento
  // excluído continua possível) e fitId pode repetir entre CONTAS diferentes
  // (bancos não coordenam esse id entre si). ATENÇÃO `migrate dev`: por não
  // estar modelado aqui, um diff futuro pode propor DROP desse índice —
  // revisar a migration gerada antes de aplicar.
  fitId String?

  installmentPurchaseId String?
  installmentNumber     Int?

  // Parcela de empréstimo (docs/03-DATABASE.md, model Loan) — análogo a
  // `installmentPurchaseId`, mas na CONTA (não cartão) e sem
  // `installmentNumber` próprio (o número da parcela vive só na
  // `description`, ex. "Maternidade - parcela 3/12"; ver
  // `modules/loans/installments.ts`).
  loanId String?

  // Aporte/resgate de investimento (docs/28-INVESTMENTS.md) — FK opcional
  // pro Asset INVESTMENT. Não altera saldo sozinho: a Transaction EXPENSE
  // na conta é o que debita; o asset sobe via `currentValue` + snapshot.
  assetId String?

  // Override do `% do CDI` neste aporte; null = usa o default do Asset.
  yieldPercentOfBenchmark Decimal? @db.Decimal(7, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category            Category?            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  account             Account?             @relation(fields: [accountId], references: [id], onDelete: Restrict)
  card                Card?                @relation(fields: [cardId], references: [id], onDelete: Restrict)
  installmentPurchase InstallmentPurchase? @relation(fields: [installmentPurchaseId], references: [id], onDelete: Restrict)
  loan                Loan?                @relation(fields: [loanId], references: [id], onDelete: Restrict)
  asset               Asset?               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  transactionTags     TransactionTag[]

  @@index([userId, date])
  @@index([accountId])
  @@index([cardId])
  @@index([categoryId])
  @@index([transferId])
  @@index([installmentPurchaseId])
  @@index([loanId])
  @@index([userId, assetId])
  @@index([accountId, fitId])
}

// ---------------------------------------------------------------------------
// Budget
// ---------------------------------------------------------------------------

model Budget {
  id            String    @id @default(cuid())
  userId        String
  categoryId    String
  month         Int
  year          Int
  plannedAmount Decimal   @db.Decimal(12, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([userId, categoryId, month, year])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Asset
// ---------------------------------------------------------------------------

model Asset {
  id            String    @id @default(cuid())
  userId        String
  name          String
  type          AssetType
  purchaseValue Decimal   @db.Decimal(12, 2)
  currentValue  Decimal   @db.Decimal(12, 2)
  purchaseDate  DateTime
  notes         String?

  // Yield só faz sentido em INVESTMENT (docs/28-INVESTMENTS.md). Demais
  // tipos ficam NONE / null. `yieldPercentOfBenchmark` = 115.00 → 115% do CDI.
  yieldBenchmark          YieldBenchmark @default(NONE)
  yieldPercentOfBenchmark Decimal?       @db.Decimal(7, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots    AssetSnapshot[]
  // Financiamentos (`kind=FINANCING`) linkados a este bem via `Loan.assetId`
  // (opcional — ver model Loan).
  loans        Loan[]
  transactions Transaction[]
  savingsGoals SavingsGoal[]

  @@index([userId])
  @@index([userId, type])
}

// ---------------------------------------------------------------------------
// SavingsGoal
// ---------------------------------------------------------------------------

// Meta de economia (docs/03-DATABASE.md) — valor-alvo com prazo opcional.
// `sourceType` define de onde vem `currentAmount`: MANUAL = editado à mão;
// ACCOUNT/ASSET = acompanha o saldo de `sourceAccountId`/`sourceAssetId`
// (derivado, recalculado sob demanda pelo módulo — não recomputado por
// trigger). `monthlyContribution` é informativo, usado só pra projeção de
// "quando bate a meta" (ver `modules/goals/`), nunca gera Transaction
// automaticamente.
model SavingsGoal {
  id                  String         @id @default(cuid())
  userId              String
  name                String
  targetAmount        Decimal        @db.Decimal(12, 2)
  targetDate          DateTime?
  sourceType          GoalSourceType @default(MANUAL)
  sourceAccountId     String?
  sourceAssetId       String?
  currentAmount       Decimal        @default(0) @db.Decimal(12, 2)
  monthlyContribution Decimal?       @db.Decimal(12, 2)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [sourceAccountId], references: [id], onDelete: SetNull)
  asset   Asset?   @relation(fields: [sourceAssetId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// MarketIndexQuote — cache diário de CDI (Gemini ou manual)
// ---------------------------------------------------------------------------

model MarketIndexQuote {
  id                String                 @id @default(cuid())
  index             MarketIndex
  // Meia-noite America/Sao_Paulo do dia cotado (mesmo padrão de datas do app).
  date              DateTime
  annualRatePercent Decimal                @db.Decimal(7, 4)
  source            MarketIndexQuoteSource
  fetchedAt         DateTime               @default(now())

  @@unique([index, date])
  @@index([index, date])
}

// ---------------------------------------------------------------------------
// AssetSnapshot (sem userId próprio, ver 03-DATABASE.md)
// ---------------------------------------------------------------------------

model AssetSnapshot {
  id        String   @id @default(cuid())
  assetId   String
  value     Decimal  @db.Decimal(12, 2)
  date      DateTime
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, date])
}

// ---------------------------------------------------------------------------
// InstallmentPurchase
// ---------------------------------------------------------------------------

model InstallmentPurchase {
  id                String   @id @default(cuid())
  userId            String
  cardId            String
  description       String
  totalAmount       Decimal  @db.Decimal(12, 2)
  installmentsCount Int
  firstDueDate      DateTime
  createdAt         DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         Card          @relation(fields: [cardId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([userId])
  @@index([cardId])
}

// ---------------------------------------------------------------------------
// Loan
// ---------------------------------------------------------------------------

// Empréstimo (docs/03-DATABASE.md) — análogo a `InstallmentPurchase`, mas na
// CONTA (não cartão) e com principal + juros. `totalToPay` inclui os juros;
// `totalToPay - principal` é o custo do empréstimo (derivado, sem coluna
// própria — mesmo princípio de "Regra de Ouro" do banco: nada denormalizado
// que dá pra calcular). Cada parcela nasce como `Transaction`
// (`type=EXPENSE`, `loanId` preenchido, `isPaid=false` — PREVISTO, diferente
// da parcela de cartão que já nasce paga) — ver `modules/loans/`.
model Loan {
  id                String   @id @default(cuid())
  userId            String
  description       String
  lender            String?
  principal         Decimal  @db.Decimal(12, 2)
  totalToPay        Decimal  @db.Decimal(12, 2)
  installmentsCount Int
  installmentAmount Decimal  @db.Decimal(12, 2)
  firstDueDate      DateTime
  accountId         String
  categoryId        String?

  // Juros OPCIONAL — default DESLIGADO (docs/03-DATABASE.md). `null` em
  // ambos = empréstimo sem juros (ex.: empréstimo entre família), parcela
  // sempre cobra o valor cheio, sem desconto de antecipação. Preenchidos
  // juntos = habilita `modules/loans/interest.ts` (taxa mensal derivada +
  // valor presente na antecipação). `interestPeriod` só faz sentido com
  // `interestRate` — nunca um sem o outro (validado no schema Zod da
  // service, não em CHECK constraint: Prisma/Postgres não expressam bem
  // "ambos nulos OU ambos preenchidos" sem trigger).
  interestRate   Decimal?        @db.Decimal(9, 6)
  interestPeriod InterestPeriod?

  // Financiamento (docs/50-AUDITORIA-BACKLOG.md) — `kind` discrimina o
  // subtipo; os campos abaixo são NULLABLE e só usados quando
  // `kind=FINANCING` (LOAN nunca preenche nenhum deles, sem regressão nos
  // empréstimos existentes, que viram `kind=LOAN` via `@default`).
  kind               LoanKind            @default(LOAN)
  amortizationSystem AmortizationSystem?

  // Entrada paga à vista (down payment) e valor total do bem financiado —
  // informativos, não entram em `principal`/`totalToPay` (que continuam
  // sendo só o que é PARCELADO). `assetId` linka opcionalmente a um `Asset`
  // já cadastrado (ex.: o carro), validado por ownership em
  // `modules/loans/ownership.ts` — nunca referencia Asset de outro usuário.
  downPayment Decimal? @db.Decimal(12, 2)
  assetValue  Decimal? @db.Decimal(12, 2)
  assetId     String?

  // CET (Custo Efetivo Total, % a.m.) — informativo, não alimenta
  // `modules/loans/interest.ts` (que continua usando só `interestRate`/
  // `interestPeriod` pra juros/antecipação/PV). `operationRef` = número da
  // operação/contrato do banco (CCB), só rótulo, sem regra de negócio.
  cet          Decimal? @db.Decimal(9, 6)
  operationRef String?

  // Custos embutidos no financiamento (IOF, seguro, tarifas+registro) — já
  // estão dentro de `principal`/`totalToPay` (o financiamento parcela o
  // valor cheio, impostos inclusos); estes campos só quebram o valor total
  // em componentes pra exibição/relatório, nunca somados de novo em cima do
  // principal.
  financedTaxes     Decimal? @db.Decimal(12, 2)
  financedInsurance Decimal? @db.Decimal(12, 2)
  financedFees      Decimal? @db.Decimal(12, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  asset        Asset?        @relation(fields: [assetId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([assetId])
}

// ---------------------------------------------------------------------------
// RecurringTransaction
// ---------------------------------------------------------------------------

model RecurringTransaction {
  id          String             @id @default(cuid())
  userId      String
  description String
  amount      Decimal            @db.Decimal(12, 2)
  type        TransactionType
  categoryId  String
  accountId   String
  frequency   RecurringFrequency
  dayOfMonth  Int?
  dayOfWeek   Int?
  active      Boolean            @default(true)
  nextRun     DateTime
  createdAt   DateTime           @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([active, nextRun])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Alert
// ---------------------------------------------------------------------------

model Alert {
  id       String        @id @default(cuid())
  userId   String
  type     AlertType
  severity AlertSeverity
  title    String
  message  String
  payload  Json

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// UserSettings (1:1 com User)
// ---------------------------------------------------------------------------

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique

  currency String @default("BRL")
  timezone String @default("America/Sao_Paulo")
  theme    Theme  @default(DARK)

  alertAnomalyMultiplier Decimal @default(1.5) @db.Decimal(4, 2)
  alertMinimumAmount     Decimal @default(50.00) @db.Decimal(12, 2)
  alertGreenMultiplier   Decimal @default(0.6) @db.Decimal(4, 2)

  // Telegram "traga seu próprio bot" (docs/30-TELEGRAM.md, "Segurança";
  // docs/12-SETTINGS.md, "3. Telegram"): cada usuário cria seu bot no
  // @BotFather e cola o token aqui — sem bot único global via env.
  // `telegramBotToken`/`telegramWebhookSecret` (gerado por usuário,
  // `crypto.randomBytes`) identificam de quem é o bot que recebeu o update
  // no webhook (`modules/telegram/webhook-auth.ts`). `telegramBotUsername`
  // e `telegramWebhookRegistered` são só pra exibição/status na UI — nunca
  // reconsultados ao vivo no Telegram a cada render (evita fetch redundante,
  // docs/01-STACK.md "Performance"); ficam desatualizados só se o webhook
  // cair fora de uma reinstalação, aceitável pra 2 usuários.
  // `telegramChatId` é o chat vinculado (self-service, `telegramLinkCode`/
  // `telegramLinkCodeExpiresAt` guardam o código temporário de 15min até a
  // confirmação via `/vincular <CODE>` ou `/start <CODE>`).
  telegramBotToken          String?
  telegramWebhookSecret     String?   @unique
  telegramBotUsername       String?
  telegramWebhookRegistered Boolean   @default(false)
  telegramChatId            String?   @unique
  telegramLinkCode          String?   @unique
  telegramLinkCodeExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// TelegramPendingEntry (rascunho de lançamento em progresso, ver 30-TELEGRAM.md)
// ---------------------------------------------------------------------------

model TelegramPendingEntry {
  id     String @id @default(cuid())
  userId String @unique

  // Rascunho serializado do lançamento (ver `modules/telegram/types.ts`,
  // `TelegramDraft`) — mesclado a cada resposta do usuário até completar.
  draftJson Json

  // Único campo faltando no momento (`"amount"` | `"origin"`) — a mensagem
  // seguinte do usuário é interpretada como resposta a ESSE campo
  // (`modules/telegram/pending-merge.ts`).
  missingField String

  // Rodadas de pergunta já feitas — trava em ~3 (docs/30-TELEGRAM.md, "Fluxo
  // conversacional") pra não ficar perguntando pra sempre se a resposta do
  // usuário nunca resolve o campo faltante.
  attempts Int @default(0)

  // TTL curto (~10min, `modules/telegram/pending.ts`) — expirado é tratado
  // como se não existisse, a mensagem seguinte vira um lançamento novo.
  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// TelegramProcessedUpdate (dedup de update_id, ver 30-TELEGRAM.md)
// ---------------------------------------------------------------------------

model TelegramProcessedUpdate {
  id     String @id @default(cuid())
  userId String

  // `update_id` do Telegram (único por bot) — a chave composta (userId,
  // updateId) é a garantia correta no modelo multi-bot BYO: cada usuário tem
  // seu próprio bot, então o mesmo update_id pode existir em usuários
  // diferentes. Evita processar (e duplicar) o mesmo update quando o
  // Telegram reenvia por timeout de resposta (route.ts).
  updateId BigInt

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, updateId])
  @@index([createdAt])
}
