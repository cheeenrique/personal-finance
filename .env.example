# Connection string do Postgres (Neon, Supabase ou Railway).
#
# Em produção na Vercel com a integração Supabase instalada, NÃO é obrigatório
# setar DATABASE_URL aqui: a integração injeta POSTGRES_URL_NON_POOLING
# (conexão direta, porta 5432) e o app (src/lib/db/client.ts, prisma.config.ts)
# cai automaticamente nessa env como fallback quando DATABASE_URL não existe.
# Se preferir, pode setar DATABASE_URL explicitamente na Vercel — nesse caso
# ela tem prioridade sobre o fallback.
DATABASE_URL=""

# Chave de assinatura de sessão do Auth.js. Gerar com: openssl rand -base64 32
AUTH_SECRET=""

# Telegram é configurado por-usuário na tela de Configurações (token +
# webhook-secret ficam em UserSettings, no banco) — não via env.

# Secret que protege os endpoints de cron (/api/cron/*).
CRON_SECRET=""
